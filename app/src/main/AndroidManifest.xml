<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:theme="@style/Theme.NothingSound"
        android:supportsRtl="true">

        <!-- Settings / "add sound" activity, also launcher entry -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.NothingSound">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- The widget provider -->
        <receiver
            android:name=".SoundWidgetProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.nothingsound.widget.ACTION_ITEM_CLICK" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_info" />
        </receiver>

        <!-- Plays a sound when the widget is tapped; no UI, dies as soon as playback ends -->
        <service
            android:name=".SoundPlayService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback" />

        <!-- Feeds the StackView its rows of sound tiles -->
        <service
            android:name=".StackRemoteViewsService"
            android:exported="false"
            android:permission="android.permission.BIND_REMOTEVIEWS" />

    </application>

</manifest>
