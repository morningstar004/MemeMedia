<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/stack_item_root"
    android:layout_width="160dp"
    android:layout_height="160dp"
    android:background="@drawable/widget_circle_bg">

    <ImageView
        android:id="@+id/tile_icon"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_centerInParent="true"
        android:contentDescription="@null"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_dot_wave" />

    <TextView
        android:id="@+id/tile_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/tile_icon"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="8dp"
        android:ellipsize="marquee"
        android:gravity="center"
        android:letterSpacing="0.1"
        android:maxLines="1"
        android:text="@string/sound_tile_label"
        android:textAllCaps="true"
        android:textColor="@color/nothing_white"
        android:textSize="12sp" />

</RelativeLayout>
